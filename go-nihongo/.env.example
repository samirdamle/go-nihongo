# Sentence MT (pluggable — ADR 0004)
# Leave unset or set MT_PROVIDER=mock to use deterministic mock translator.
MT_PROVIDER=
GOOGLE_CLOUD_TRANSLATION_API_KEY=

# OpenRouter LLM gateway (server-only — ADR 0007)
# Add your key in .env.local (never commit secrets).
# https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Default: NVIDIA Nemotron free (transliteration + translations). Override as needed.
OPENROUTER_MODEL=nvidia/nemotron-3-ultra-550b-a55b:free
# Optional overrides
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_SITE_URL=https://example.com
# OPENROUTER_SITE_NAME=Go Nihongo!
# Force mock LLM even if key is set (CI/local)
# LLM_PROVIDER=mock
# MT: mock | openrouter | google (default: openrouter when key set, else google, else mock)
# MT_PROVIDER=

# Optional (not on silent dictionary path)
# GEMINI_API_KEY=
